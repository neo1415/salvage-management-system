# Database (Supabase)
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
DATABASE_URL=your-database-url

# Test Database (Optional - Use Session Mode Pooler with minimal connections for Integration Tests)
# Use the same DATABASE_URL as production but tests will use a smaller connection pool (2 connections)
# This prevents connection pool exhaustion during integration tests
# Format: postgresql://postgres.[project-ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
# TEST_DATABASE_URL=your-test-database-url

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# Vercel KV (Redis)
KV_REST_API_READ_ONLY_TOKEN=your-kv-read-only-token
KV_REST_API_TOKEN=your-kv-api-token
KV_REST_API_URL=your-kv-rest-api-url
KV_URL=your-kv-url
REDIS_URL=your-redis-url

# Development: Disable rate limiting for registration (NEVER use in production)
# Set to true to bypass registration rate limits during development/testing
# WARNING: This removes protection against spam registrations
DISABLE_REGISTRATION_RATE_LIMIT=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google Cloud
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./google-cloud-credentials.json
GOOGLE_CLOUD_VISION_API_KEY=your-api-key
GOOGLE_CLOUD_DOCUMENT_AI_API_KEY=your-api-key

# Claude AI (Primary - for enhanced damage detection)
# Get API key from: https://console.anthropic.com/
# Uses Claude 3.5 Haiku with prompt caching for cost optimization
# Estimated cost: $0.43/month for 45 assessments with 10 images
# Fallback chain: Claude → Gemini → Vision API
CLAUDE_API_KEY=your-claude-api-key

# Google Gemini AI (Secondary fallback - for enhanced damage detection)
# Get API key from: https://aistudio.google.com/apikey
# Free tier: 10 requests/minute, 1,500 requests/day
# Used as fallback when Claude is unavailable
GEMINI_API_KEY=your-gemini-api-key

# AI Assessment Mock Mode (set to true for testing without Google Cloud billing)
# When true, generates fake AI assessment data instead of calling Google Cloud Vision API
# Set to false in production after enabling billing
MOCK_AI_ASSESSMENT=true

# Google Maps (for accurate geolocation)
# Get API key from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Geolocation API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Payment Providers
PAYSTACK_SECRET_KEY=your-paystack-secret-key
# Paystack Configuration
# Get these from: https://dashboard.paystack.com/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxx  # Used for BOTH API calls AND webhook signature verification
PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxx

# Paystack Transfer Recipient Code for NEM Insurance (see PAYSTACK_TRANSFERS_SETUP_GUIDE.md)
PAYSTACK_NEM_RECIPIENT_CODE=your-nem-recipient-code

# IMPORTANT: Configure webhook URL in Paystack Dashboard
# Go to: Settings → Webhooks → Add Webhook URL
# URL: https://your-domain.com/api/webhooks/paystack-auction
# Event: charge.success
# See: docs/PAYSTACK_WEBHOOK_SETUP_GUIDE.md
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key
FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key
FLUTTERWAVE_WEBHOOK_SECRET=your-flutterwave-webhook-secret

# SMS Provider
TERMII_API_KEY=your-termii-api-key
TERMII_SECRET_KEY=your-termii-secret-key
TERMII_SENDER_ID=your-sender-id

# SMS Provider Fallback (Africa's Talking)
AFRICAS_TALKING_API_KEY=your-africas-talking-api-key
AFRICAS_TALKING_USERNAME=your-africas-talking-username
AFRICAS_TALKING_SENDER_ID=your-sender-id

# Email Provider
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=Your Name <your-email@example.com>

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron Job Security
CRON_SECRET=your-secure-random-secret-key-here

# Auction Deposit System - Testing Mode
# Set TESTING_MODE=true to use shorter time periods for testing cron jobs
# WARNING: Only use in development/staging environments, never in production
TESTING_MODE=false

# Testing mode time overrides (in minutes)
# Document validity period (default: 48 hours = 2880 minutes, testing: 5 minutes)
TESTING_DOCUMENT_VALIDITY_MINUTES=5

# Payment deadline after signing (default: 72 hours = 4320 minutes, testing: 10 minutes)
TESTING_PAYMENT_DEADLINE_MINUTES=10

# Fallback buffer period (default: 24 hours = 1440 minutes, testing: 2 minutes)
TESTING_BUFFER_MINUTES=2

# Grace extension duration (default: 24 hours = 1440 minutes, testing: 5 minutes)
TESTING_EXTENSION_MINUTES=5

# BVN Verification
MONO_SECRET_KEY=your-mono-secret

# TinyPNG
TINYPNG_API_KEY=your-tinypng-api-key

# Deployment Seeding Configuration
# Control automatic seed execution during deployment
# SKIP_SEEDS: Set to true to skip seed execution (default: false)
# FORCE_SEEDS: Set to true to force re-run seeds even if already executed (default: false)
SKIP_SEEDS=false
FORCE_SEEDS=false

# Dojah KYC Integration
# Get credentials from: https://dojah.io/dashboard
# DOJAH_API_KEY: Your private/secret key for API calls (e.g., test_sk_xxx or live_sk_xxx)
# DOJAH_PUBLIC_KEY: Your public key for the widget (e.g., test_pk_xxx or live_pk_xxx)
# DOJAH_APP_ID: Your application ID
# DOJAH_WIDGET_ID: (Optional) Custom widget configuration ID
DOJAH_API_KEY=your-dojah-api-key
DOJAH_PUBLIC_KEY=your-dojah-public-key
DOJAH_APP_ID=your-dojah-app-id
# DOJAH_WIDGET_ID=your-widget-id

# AI Marketplace Intelligence System
# Enable/disable the intelligence features (predictions, recommendations, fraud detection)
INTELLIGENCE_ENABLED=true

# Algorithm version for tracking and rollback
INTELLIGENCE_ALGORITHM_VERSION=v1.2.0

# Redis configuration for intelligence caching
# Predictions cached for 5 minutes, recommendations for 15 minutes
INTELLIGENCE_REDIS_TTL_PREDICTIONS=300
INTELLIGENCE_REDIS_TTL_RECOMMENDATIONS=900

# PostGIS extension for geographic analytics (requires PostgreSQL with PostGIS)
# Set to true if PostGIS is installed and enabled in your database
POSTGIS_ENABLED=false
