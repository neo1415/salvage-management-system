# Copy to .env.staging (gitignored). Used only by npm run db:bootstrap-staging
# Get URI from Supabase → project esdsufyxydzrertmgyie → Settings → Database → Session pooler (5432)
STAGING_DATABASE_URL=postgresql://postgres.esdsufyxydzrertmgyie:YOUR_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Dojah KYC
# Server-side keys are never exposed to the browser.
DOJAH_APP_ID=your-dojah-app-id
DOJAH_PUBLIC_KEY=your-dojah-public-key
DOJAH_API_KEY=your-dojah-private-key
DOJAH_WIDGET_ID=your-default-widget-id

# Prefer a dedicated liveness-only widget for the manual Tier 2 face check.
# If omitted, the app falls back to DOJAH_WIDGET_ID.
DOJAH_LIVENESS_WIDGET_ID=your-liveness-widget-id
DOJAH_WORKFLOW_SLUG=salvage
